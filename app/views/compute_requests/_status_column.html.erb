<%# Local variables: status (string), requests (array of ComputeRequests) %>

<div class="flex flex-col min-w-[250px]">

  <%# Column Header %>
  <div class="flex items-center p-3 bg-gray-100 rounded-md">
    <div class="flex-1 flex justify-start">
      <div class="<%= status_indicator(status) %>"></div>
    </div>
    <span class="font-bold text-sm text-center uppercase tracking-wide">
      <%= status.titleize %>
    </span>
    <span class="flex-1 text-sm text-right text-gray-500">
      <%= requests.size %>
    </span>
  </div>

  <%# Column Body %>
  <div class="p-2 rounded-md bg-gray-50 min-h-[200px] space-y-3">
    <% requests.each do |compute_request| %>
      <%= render "kanban_card", compute_request: compute_request %>
    <% end %>

    <% if requests.empty? %>
      <p class="text-sm text-gray-400 text-center py-4">No requests</p>
    <% end %>
  </div>

</div>