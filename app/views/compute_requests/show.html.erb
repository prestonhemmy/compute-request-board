<% content_for :title, "Showing compute request" %>

<div class="max-w-2xl mx-auto">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing Request</h1>

  <%= render @compute_request %>

  <% if @compute_request.persisted? %>
    <div class="my-5">
      <h2 class="font-bold text-lg mb-2">Update Status</h2>
      <%= form_with(model: @compute_request, class: "flex items-center gap-3") do |form| %>
        <%= form.select :status, ComputeRequest.statuses.keys, {},
                        class: "rounded-md border border-gray-400 px-3 py-2" %>
        <%= form.submit "Update Status",
                        class: "rounded-md px-3.5 py-2.5 bg-slate-600 hover:bg-slate-500 text-white font-medium cursor-pointer" %>
      <% end %>
    </div>
  <% end %>

  <div class="mt-6 space-y-2">
    <%= link_to "Edit this request", edit_compute_request_path(@compute_request),
                class: "block w-full text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium" %>
    <%= link_to "Back to compute requests", compute_requests_path,
                class: "block w-full text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 font-medium" %>
    <%= button_to "Destroy this request", @compute_request, method: :delete, form_class: "",
                  class: "block w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer",
                  data: { turbo_confirm: "Are you sure? This action cannot be undone." } %>
  </div>
</div>
