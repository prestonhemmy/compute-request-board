<%= form_with(model: compute_request, class: "contents") do |form| %>
  <% if compute_request.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(compute_request.errors.count, "error") %> prohibited this compute_request from being saved:</h2>

      <ul class="list-disc ml-6">
        <% compute_request.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :title, class: "w-1/4 font-medium" %>
    <%= form.text_field :title,
                        class: field_classes(compute_request, :title) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :user_id, class: "w-1/4 font-medium" %>
    <%= form.collection_select :user_id, User.all, :id, :name, {},
                               class: field_classes(compute_request, :user_id) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :gpu_count, "GPU Count", class: "w-1/4 font-medium" %>
    <%= form.number_field :gpu_count, min: 1, max: 8,
                          class: field_classes(compute_request, :gpu_count) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :cpu_cores, "CPU Cores", class: "w-1/4 font-medium" %>
    <%= form.number_field :cpu_cores, min: 1, max: 40,
                          class: field_classes(compute_request, :cpu_cores) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :memory_gb, "Memory (GB)", class: "w-1/4 font-medium" %>
    <%= form.number_field :memory_gb, min: 1, max: 512,
                          class: field_classes(compute_request, :memory_gb) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :hours, class: "w-1/4 font-medium" %>
    <%= form.number_field :hours, min: 1, max: 72,
                          class: field_classes(compute_request, :hours) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :partition, class: "w-1/4 font-medium" %>
    <%= form.select :partition, ComputeRequest.partitions.keys, {},
                    class: field_classes(compute_request, :partition) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :priority, class: "w-1/4 font-medium" %>
    <%= form.select :priority, ComputeRequest.priorities.keys, {},
                    class: field_classes(compute_request, :priority) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :status, class: "w-1/4 font-medium" %>

    <%# status field editable unless new request %>
    <%= form.select :status, ComputeRequest.statuses.keys, {},
                    class: field_classes(compute_request, :status),
                    disabled: @compute_request.new_record? %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :notes, class: "w-1/4 font-medium"  %>
    <%= form.textarea :notes, rows: 4,
                      class: field_classes(compute_request, :notes) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :created_at, "Created At", class: "w-1/4 font-medium" %>
    <%= form.datetime_field :created_at,
                            class: field_classes(compute_request, :created_at) %>
  </div>

  <div class="my-5 flex items-center gap-4">
    <%= form.label :updated_at, "Updated At", class: "w-1/4 font-medium" %>
    <%= form.datetime_field :updated_at,
                            class: field_classes(compute_request, :updated_at) %>
  </div>

  <div class="inline">
    <%= form.submit class: "block w-full rounded-md px-3.5 py-2.5 bg-slate-600 hover:bg-slate-500 text-white font-medium cursor-pointer" %>
  </div>
<% end %>
