<%= form_with(model: compute_request, class: "contents") do |form| %>
  <% if compute_request.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(compute_request.errors.count, "error") %> prohibited this compute_request from being saved:</h2>

      <ul class="list-disc ml-6">
        <% compute_request.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :title %>
    <%= form.text_field :title, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:title].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:title].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :gpu_count %>
    <%= form.number_field :gpu_count, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:gpu_count].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:gpu_count].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :cpu_count %>
    <%= form.number_field :cpu_count, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:cpu_count].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:cpu_count].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :memory_gb %>
    <%= form.number_field :memory_gb, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:memory_gb].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:memory_gb].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :hours %>
    <%= form.number_field :hours, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:hours].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:hours].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :partition %>
    <%= form.text_field :partition, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:partition].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:partition].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :priority %>
    <%= form.text_field :priority, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:priority].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:priority].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :status %>
    <%= form.text_field :status, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:status].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:status].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :notes %>
    <%= form.textarea :notes, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:notes].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:notes].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :created_at %>
    <%= form.datetime_field :created_at, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:created_at].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:created_at].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :updated_at %>
    <%= form.datetime_field :updated_at, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": compute_request.errors[:updated_at].none?, "border-red-400 focus:outline-red-600": compute_request.errors[:updated_at].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
