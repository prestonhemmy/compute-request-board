<% content_for :title, "Compute Request Board" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <%# Header %>
  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl">Compute Request Board</h1>
    <%= link_to "New compute request", new_compute_request_path,
                class: "rounded-md px-3.5 py-2.5 bg-slate-600 hover:bg-slate-500 text-white block font-medium" %>
  </div>

  <%# Filter Bar %>
  <div class="mb-6">
    <%= form_with url: compute_requests_path, method: :get do |form| %>

      <div class="flex flex-col py-1">
        <%= label_tag :priority, "Priority", class: "text-sm font-medium text-gray-700 mb-1" %>
        <%= select_tag :priority,
                       options_for_select(
                         [["All", ""]] + ComputeRequest.priorities.keys.map { |p| [p.capitalize, p] },
                         params[:priority]
                       ),
                       class: "rounded-md border border-gray-400 px-3 py-2 text-sm" %>
      </div>

      <div class="flex flex-col py-1">
        <%= label_tag :lab, "Lab", class: "text-sm font-medium text-gray-700 mb-1" %>
        <%= select_tag :lab,
                       options_for_select(
                         [["All", ""]] + User.distinct.pluck(:lab).compact.map { |l| [l, l] },
                         params[:lab]
                       ),
                       class: "rounded-md border border-gray-400 px-3 py-2 text-sm" %>
      </div>

      <%= submit_tag "Filter",
                     class: "rounded-md px-3.5 py-2 bg-slate-600 hover:bg-slate-500 text-white text-sm font-medium cursor-pointer" %>

      <% if params[:priority].present? || params[:lab].present? %>
        <%= link_to "Clear", compute_requests_path,
                    class: "rounded-md px-3.5 py-2 bg-gray-200 hover:bg-gray-100 text-sm font-medium" %>
      <% end %>

    <% end %>
  </div>

  <%# Dashboard %>
  <%= render "dashboard", total_requests: @total_requests, gpu_count: @gpu_count,
             pending_cpu_hours: @pending_cpu_hours, urgent_count: @urgent_count %>

  <%# Kanban Board %>
  <div class="flex gap-4 overflow-x-auto">
    <% ComputeRequest.statuses.keys.each do |status| %>
      <%# fetch requests for this status from the controller's grouped data %>
      <% requests = @grouped_requests[status] || [] %>

      <%# Column header — status name and count %>
      <%= render "status_column", status: status, requests: requests %>
    <% end %>
  </div>

</div>
